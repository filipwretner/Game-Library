{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-code-review.ps1\"",
            "timeout": 15,
            "statusMessage": "Checking for code-review request"
          }
        ]
      }
    ]
  }
}
