{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  // vite.config.ts is intentionally excluded from typecheck: Vite/Vitest load it via
  // esbuild, and @tailwindcss/vite pulls a second (lightningcss) vite copy whose Plugin
  // type only nominally differs, which would otherwise error here.
  "include": ["src"]
}
