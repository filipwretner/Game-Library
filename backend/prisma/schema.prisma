// Prisma schema — SQLite, single-file DB (spec §3, §5).
// SQLite has no native enums, so status/ownedPlatform are stored as strings and
// constrained by Zod at the HTTP boundary + the shared domain types.
// Ordinal-only ranking decision: no `rating` column.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Cached metadata from IGDB. One row per referenced game, never duplicated.
model Game {
  id          Int      @id @default(autoincrement())
  igdbId      Int      @unique
  title       String
  coverUrl    String?
  summary     String?
  releaseDate DateTime?
  /// JSON-encoded array of IGDB platform ids — drives preferredPlatform() (§6).
  platforms   String   @default("[]")
  igdbRating  Float?
  cachedAt    DateTime @default(now())

  entry        Entry?
  customEntries CustomListEntry[]
}

/// A user-created list (e.g. "Top 10 Games of 2024"). Independent of the three
/// core lists; a game may be here and on a core list at the same time.
model CustomList {
  id        Int               @id @default(autoincrement())
  title     String
  createdAt DateTime          @default(now())
  entries   CustomListEntry[]
}

/// A game's membership + rank within one custom list.
model CustomListEntry {
  id        Int        @id @default(autoincrement())
  listId    Int
  list      CustomList @relation(fields: [listId], references: [id], onDelete: Cascade)
  gameId    Int
  game      Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  rank      Int
  createdAt DateTime   @default(now())

  @@unique([listId, gameId])
  @@index([listId, rank])
}

/// A game's presence on exactly one list (PLAYED | BACKLOG | WISHLIST).
model Entry {
  id     Int    @id @default(autoincrement())
  gameId Int    @unique
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  /// "PLAYED" | "BACKLOG" | "WISHLIST"
  status String

  /// Ordering within PLAYED, 1 = best. Null otherwise.
  rank Int?

  /// "PC" | "PS5" — version owned/played (BACKLOG/PLAYED).
  ownedPlatform String?

  // Wishlist pricing (§2.2 CheapShark for PC, manual for PS5).
  price          Float?
  normalPrice    Float?
  discountPct    Int?
  priceCurrency  String?
  priceStore     String?
  priceUpdatedAt DateTime?

  dateCompleted DateTime?
  notes         String?
  createdAt     DateTime  @default(now())

  @@index([status, rank])
}
