# Copy to .env and fill in. Never commit .env (git-ignored).

# Backend HTTP port
PORT=3001

# SQLite database file (relative to backend/). Backed up by copying the file.
DATABASE_URL="file:./data/app.db"

# IGDB via Twitch OAuth2 — register an app at https://dev.twitch.tv/console/apps
# Required from Milestone 2 onward; leave blank for tooling/skeleton work.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Default currency for wishlist prices (pinned to USD for v1).
PRICE_CURRENCY=USD
